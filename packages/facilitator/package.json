    "hono": "4.12.22",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@cloudflare/vitest-pool-workers": "0.16.9",
    "vitest": "catalog:",
    "wrangler": "4.94.0"
  }
