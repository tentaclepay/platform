{
  "compatibility_date": "2026-05-31",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "tentaclepay-web",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "fe7e9d5e82b541d5892c824b2376abb9"
    }
  ],
  "observability": {
    "enabled": true
  }
}
