---
import { ArrowUpRight } from "@lucide/astro";
import { Github, X } from "simple-icons-astro";

import { LINKS } from "@/consts";

const socials = [
  { label: "GitHub", href: LINKS.github, Icon: Github },
  { label: "X", href: LINKS.x, Icon: X },
];

const productLinks = [
  { label: "Payments", href: "#payments" },
  { label: "Cross-Chain", href: "#cross-chain" },
  { label: "Wallet", href: "#wallet" },
];

const resourceLinks = [
  { label: "Docs", href: LINKS.docs },
  { label: "GitHub", href: LINKS.github },
];
---

<footer
  class="relative w-full overflow-hidden border-t border-border bg-background"
>
  <div class="container mx-auto px-6 pb-10 pt-16">
    <div data-reveal-group class="grid gap-12 md:grid-cols-[1.5fr_1fr_1fr]">
      <!-- Brand -->
      <div class="flex flex-col gap-4">
        <a
          href="#hero"
          class="flex w-fit items-center gap-3 transition-transform duration-150 ease-out active:scale-[0.98]"
        >
          <img
            src="/logo.svg"
            alt=""
            width="256"
            height="256"
            class="h-9 w-9"
          />
          <span
            class="font-heading text-2xl uppercase leading-none tracking-wide text-foreground"
          >
            Tentacle<span class="text-primary">Pay</span>
          </span>
        </a>
        <p class="max-w-xs text-sm leading-relaxed text-foreground/50">
          Payment infrastructure for autonomous agents on Sui.
        </p>
        <div class="flex items-center gap-2 pt-1">
          {
            socials.map(({ label, href, Icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="inline-flex size-9 items-center justify-center border border-border text-muted-foreground transition-colors duration-150 ease-out hover:border-primary hover:text-foreground"
              >
                <Icon class="size-4" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Product -->
      <nav aria-label="Product" class="flex flex-col gap-4">
        <span
          class="font-mono text-xs uppercase tracking-widest text-muted-foreground"
        >
          // Product
        </span>
        <ul class="flex flex-col gap-3">
          {
            productLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="group inline-flex items-baseline gap-2 text-sm text-foreground/60 transition-colors duration-150 ease-out hover:text-foreground"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Resources -->
      <nav aria-label="Resources" class="flex flex-col gap-4">
        <span
          class="font-mono text-xs uppercase tracking-widest text-muted-foreground"
        >
          // Resources
        </span>
        <ul class="flex flex-col gap-3">
          {
            resourceLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-sm text-foreground/60 transition-colors duration-150 ease-out hover:text-foreground"
                >
                  {label}
                  <ArrowUpRight class="size-3.5 text-primary" />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-14 flex flex-col-reverse items-start gap-4 border-t border-border pt-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-xs text-foreground/40">
        © {new Date().getFullYear()} Tentacle Pay. All rights reserved.
      </p>
      <span class="inline-flex items-center gap-2">
        <span class="text-xs text-foreground/40">Built on</span>
        <img
          src="/sui_full_white.svg"
          alt="Sui"
          width="84"
          height="32"
          class="h-4 w-auto opacity-40"
        />
      </span>
    </div>
  </div>

  <!-- Giant wordmark, clipped at the abyss floor -->
  <div
    aria-hidden="true"
    class="hidden md:block pointer-events-none select-none overflow-hidden"
  >
    <p
      class="p-4 -mb-[0.4em] whitespace-nowrap text-center font-heading text-[clamp(8.5rem,26.5vw,26rem)] uppercase leading-[0.8] tracking-wide text-transparent [-webkit-text-stroke:2px_var(--primary)] opacity-20"
    >
      Tentacle Pay
    </p>
  </div>
</footer>
