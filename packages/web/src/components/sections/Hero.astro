---
import { ChevronRight } from "@lucide/astro";
---

<section
  id="hero"
  class="flex w-full h-screen bg-[url('/backgrounds/hero.webp')] bg-cover bg-position-[60%] md:bg-center bg-no-repeat"
>
  <div
    class="flex flex-col container mx-auto justify-center md:justify-start md:pt-72 px-6 gap-6"
  >
    <div class="flex flex-col">
      <h1 class="font-heading uppercase text-8xl">
        Let your <br />agents <span class="text-primary">transact</span>
      </h1>
      <p class="text-sm text-foreground/60">
        Agents are already running code. Now, let them run the economy.
      </p>
    </div>
    <div class="flex flex-col gap-2">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
        <a
          href="#payments"
          class="inline-flex w-fit bg-primary font-mono text-primary-foreground hover:bg-primary/80 active:scale-[0.97] transition-[transform,background-color] duration-150 ease-out px-5 h-10 rounded-lg items-center justify-center font-medium"
        >
          Explore
        </a>
        <a
          href="https://docs.tentaclepay.com"
          target="_blank"
          rel="noreferrer"
          class="inline-flex w-fit font-mono text-foreground border border-primary/60 hover:border-primary active:scale-[0.97] transition-[transform,border] duration-150 ease-out px-5 pr-3 gap-1.5 h-10 rounded-lg items-center justify-center font-medium"
        >
          Read the docs
          <ChevronRight class="size-4" />
        </a>
      </div>
      <p
        class="flex flex-col gap-2.5 items-start md:inline-flex md:flex-row md:items-end"
      >
        <span class="text-foreground/40 text-sm">
          Built exclusively for autonomous agents on
        </span>
        <img
          src="/sui_full_white.svg"
          alt="Sui"
          class="inline-flex h-6 w-auto opacity-50"
        />
      </p>
    </div>
  </div>
</section>
