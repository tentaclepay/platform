<section
  id="cross-chain"
  aria-labelledby="cross-chain-heading"
  class="relative flex min-h-screen w-full items-center overflow-hidden py-28 md:py-24"
>
  <!-- Background: coin tentacles (left-aligned on desktop, full-bleed dimmed on mobile) -->
  <div
    class="absolute inset-0 z-0 select-none pointer-events-none"
    aria-hidden="true"
  >
    <img
      data-img-reveal
      src="/images/crosschain.webp"
      alt=""
      width="4100"
      height="4096"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover object-center brightness-40 mask-[radial-gradient(closest-side,black_70%,transparent)] md:inset-y-0 md:right-auto md:left-32 md:h-full md:w-auto md:max-w-[50%] md:object-contain md:object-left md:brightness-85"
    />
  </div>

  <div
    class="relative z-10 container mx-auto grid items-center gap-12 px-6 md:grid-cols-2 md:gap-16"
  >
    <!-- Right: content (col 2 on desktop) -->
    <div class="flex flex-col gap-7 md:col-start-2">
      <div class="flex flex-col gap-4">
        <p
          data-reveal
          class="font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
        >
          // Cross-Chain
        </p>
        <h2
          id="cross-chain-heading"
          data-split
          class="font-heading text-[clamp(3.75rem,8.5vw,7.5rem)] uppercase leading-[0.85] tracking-wide"
        >
          Across the <span class="text-primary">sea</span>
        </h2>
      </div>

      <div data-reveal-group class="flex flex-col gap-6">
        <p class="max-w-md text-sm text-foreground/60">
          One Sui wallet. Every chain.
        </p>

        <p class="max-w-md text-base leading-relaxed text-foreground/70">
          Pay for services on other chains straight from your
          <span class="font-medium text-foreground">Sui wallet</span>, in
          <span class="font-medium text-foreground">Sui stablecoins</span>. No
          juggling a wallet per chain — keep one wallet and let your agents pay
          <span class="font-medium text-primary">everywhere</span>.
        </p>

        <p class="max-w-md text-base leading-relaxed text-foreground/70">
          Your agent keeps a single Sui wallet. Pay for services wherever they
          live. Spend the coins you already hold.
        </p>

        <span
          class="inline-flex h-10 w-fit select-none items-center gap-2 border border-primary px-5 font-mono text-xs font-medium uppercase tracking-widest text-primary"
        >
          <span class="size-1 bg-primary"></span>
          Coming soon
        </span>
      </div>
    </div>
  </div>
</section>
