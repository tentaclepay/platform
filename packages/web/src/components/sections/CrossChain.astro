<section
  id="cross-chain"
  class="relative w-full min-h-screen flex items-center py-24 md:py-0 overflow-hidden"
>
  <!-- Background slot (LEFT). Image to be supplied later → /backgrounds/crosschain.webp -->
  <div
    class="absolute inset-0 z-0 select-none pointer-events-none"
    aria-hidden="true"
  >
    {
      /* TODO: add /backgrounds/crosschain.webp, then uncomment:
    <img
      src="/backgrounds/crosschain.webp"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-center brightness-40 md:inset-y-0 md:right-auto md:left-0 md:h-full md:w-auto md:max-w-[60%] md:object-contain md:object-left md:brightness-75 mask-[radial-gradient(closest-side,black_70%,transparent)]"
      loading="lazy"
      decoding="async"
    />
    */
    }
  </div>

  <div
    class="relative z-10 container mx-auto grid items-center gap-12 px-6 md:grid-cols-2 md:gap-16"
  >
    <!-- Right: content (col 2 on desktop) -->
    <div class="flex flex-col gap-6 md:col-start-2">
      <div class="flex flex-col gap-3">
        <span
          class="font-mono text-xs uppercase tracking-widest text-muted-foreground"
        >
          // Cross-Chain
        </span>
        <h2 class="font-heading uppercase text-6xl md:text-8xl leading-[0.95]">
          Across the <span class="text-primary">Sea</span>
        </h2>
        <p class="text-sm text-foreground/60 max-w-md">
          One Sui wallet. Every chain.
        </p>
      </div>

      <p class="text-base text-foreground/70 max-w-md leading-relaxed">
        Pay for services on other chains straight from your
        <span class="text-foreground font-medium">Sui wallet</span>, in
        <span class="text-foreground font-medium">Sui stablecoins</span>. No
        juggling a wallet per chain — keep one wallet and let your agents pay
        <span class="text-primary font-medium">everywhere</span>.
      </p>

      <span
        class="inline-flex w-fit items-center gap-1.5 rounded-lg border border-border px-5 h-9 font-mono font-medium text-sm text-muted-foreground cursor-not-allowed select-none"
      >
        Coming soon
      </span>
    </div>
  </div>
</section>
