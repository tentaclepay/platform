---
import { Star } from "@lucide/astro";
import { Github } from "simple-icons-astro";

import { LINKS } from "@/consts";
---

<section
  id="cta"
  aria-labelledby="cta-heading"
  class="relative flex min-h-screen w-full items-center overflow-hidden py-28 md:py-24"
>
  <!-- Flat sonar rings where the glow used to live -->
  <div
    class="absolute inset-0 z-0 hidden md:flex items-center justify-center select-none pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute size-136 max-w-[90vw] rounded-full border-2 border-primary/30"
    >
    </div>
    <div
      class="absolute size-192 max-w-[130vw] rounded-full border-2 border-primary/20"
    >
    </div>
    <div class="absolute size-256 rounded-full border-2 border-primary/15">
    </div>
  </div>

  <div class="relative z-10 container mx-auto px-6">
    <div class="flex flex-col items-center gap-7 text-center">
      <p
        data-reveal
        class="font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
      >
        // Agentic economy
      </p>
      <h2
        id="cta-heading"
        data-split
        class="max-w-4xl font-heading text-5xl md:text-[clamp(3.75rem,9vw,8rem)] uppercase leading-[0.85] tracking-wide"
      >
        <span class="text-primary">Agents</span>
        <span
          class="text-transparent [-webkit-text-stroke:2px_var(--foreground)]"
          >transact</span
        ><br />capital
        <span class="text-transparent [-webkit-text-stroke:2px_var(--primary)]">
          moves</span
        >
      </h2>

      <div data-reveal-group class="flex flex-col items-center gap-7">
        <p class="max-w-md text-base leading-relaxed text-foreground/60">
          Tentacle Pay is open source. Read the code, wire up the rails, and put
          your agents to work — gasless on Sui.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
          <a
            href={LINKS.github}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex h-11 w-fit items-center justify-center gap-2 bg-primary px-6 font-mono text-sm font-medium uppercase tracking-wider text-primary-foreground transition-colors duration-150 ease-out hover:bg-accent active:scale-[0.97]"
          >
            <Github class="size-4" />
            Star on GitHub
            <Star class="size-4 group-hover:fill-background" />
          </a>
          <a
            href={LINKS.docs}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 w-fit items-center justify-center gap-2 border border-border px-6 font-mono text-sm font-medium uppercase tracking-wider text-foreground transition-colors duration-150 ease-out hover:border-primary hover:text-primary active:scale-[0.97]"
          >
            Read the docs
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
