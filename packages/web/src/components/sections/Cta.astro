---
import { ChevronRight, Star } from "@lucide/astro";
import { Github } from "simple-icons-astro";
---

<section
  id="cta"
  class="relative w-full min-h-screen flex items-center py-24 md:py-0 overflow-hidden"
>
  <!-- Soft primary glow -->
  <div
    class="absolute inset-0 z-0 flex items-center justify-center select-none pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="size-[36rem] max-w-full rounded-full bg-primary/15 blur-[140px]"
    >
    </div>
  </div>

  <div class="relative z-10 container mx-auto px-6">
    <div class="flex flex-col items-center text-center gap-6">
      <span
        class="font-mono text-xs uppercase tracking-widest text-muted-foreground"
      >
        // Agentic economy
      </span>
      <h2
        class="font-heading uppercase text-6xl md:text-8xl leading-[0.95] max-w-4xl"
      >
        Agents <span class="text-primary">transact</span><br /><span
          class="text-primary">capital</span
        > moves
      </h2>
      <p class="text-base text-foreground/60 max-w-md leading-relaxed">
        Tentacle Pay is open source. Read the code, wire up the rails, and put
        your agents to work — gasless on Sui.
      </p>

      <div
        class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 pt-2"
      >
        <a
          href="https://github.com/tentaclepay"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-fit items-center justify-center gap-2 bg-primary font-mono text-primary-foreground hover:bg-primary/80 active:scale-[0.97] transition-[transform,background-color] duration-150 ease-out px-5 h-10 rounded-lg font-medium"
        >
          <Github class="size-4" />
          Star on GitHub
          <Star class="size-4" />
        </a>
        <a
          href="https://docs.tentaclepay.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-fit items-center justify-center gap-1.5 font-mono text-foreground border border-primary/60 hover:border-primary active:scale-[0.97] transition-[transform,border] duration-150 ease-out px-5 pr-3 h-10 rounded-lg font-medium"
        >
          Read the docs
          <ChevronRight class="size-4" />
        </a>
      </div>
    </div>
  </div>
</section>
