---
import { Bot, Coins, Globe, ShieldCheck } from "@lucide/astro";

const features = [
  {
    icon: Bot,
    label: "Made for agents",
    body: "Your agent holds it and pays on its own — no human in the loop.",
  },
  {
    icon: ShieldCheck,
    label: "Rules it can't break",
    body: "Set the limits. The wallet enforces them on every spend.",
  },
  {
    icon: Coins,
    label: "Gasless on Sui",
    body: "Pay in Sui stablecoins. Zero gas, every payment.",
  },
  {
    icon: Globe,
    label: "Pay across chains",
    body: "Pay in Sui — it settles on the destination chain. Built right in.",
  },
] as const;
---

<section
  id="wallet"
  aria-labelledby="wallet-heading"
  class="relative flex min-h-screen w-full items-center overflow-hidden py-28 md:py-24"
>
  <!-- Background: tentacle holding the key (right-aligned on desktop) -->
  <div
    class="absolute inset-0 z-0 select-none pointer-events-none"
    aria-hidden="true"
  >
    <img
      data-img-reveal
      src="/images/wallet.webp"
      alt=""
      width="1792"
      height="2400"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover object-center brightness-40 mask-[radial-gradient(closest-side,black_70%,transparent)] md:inset-y-0 md:left-auto md:right-48 md:h-full md:w-auto md:max-w-[60%] md:object-contain md:object-right md:brightness-75"
    />
  </div>

  <div
    class="relative z-10 container mx-auto grid items-center gap-12 px-6 md:grid-cols-2 md:gap-16"
  >
    <!-- Left: content -->
    <div class="flex flex-col gap-7">
      <div class="flex flex-col gap-4">
        <p
          data-reveal
          class="font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
        >
          // Wallet
        </p>
        <h2
          id="wallet-heading"
          data-split
          class="font-heading text-[clamp(3.75rem,8.5vw,7.5rem)] uppercase leading-[0.85] tracking-wide"
        >
          Let your agents spend in <span class="text-primary">control</span>
        </h2>
      </div>

      <div data-reveal-group class="flex flex-col gap-6">
        <p class="max-w-md text-sm text-foreground/60">
          Built for autonomous agents on Sui. Inspired by <a
            href="https://openwallet.sh"
            target="_blank"
            rel="noopener noreferrer"
            class="underline decoration-dotted underline-offset-4 transition-colors hover:text-primary"
            >OWS</a
          >.
        </p>

        <ul class="grid max-w-xl grid-cols-1 gap-x-10 gap-y-6 sm:grid-cols-2">
          {
            features.map(({ icon: Icon, label, body }) => (
              <li class="flex flex-col gap-2">
                <span class="flex items-center gap-2.5">
                  <Icon class="size-4 shrink-0 text-primary" />
                  <span class="font-mono text-xs font-medium uppercase tracking-widest text-foreground">
                    {label}
                  </span>
                </span>
                <span class="text-sm leading-relaxed text-foreground/60">
                  {body}
                </span>
              </li>
            ))
          }
        </ul>

        <span
          class="inline-flex h-10 w-fit select-none items-center gap-2 border border-primary px-5 font-mono text-xs font-medium uppercase tracking-widest text-primary"
        >
          <span class="size-1 bg-primary"></span>
          Coming soon
        </span>
      </div>
    </div>
  </div>
</section>
